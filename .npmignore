# Exclude tarballs to prevent nested packaging
*.tgz
*.tar.gz
dist/*.tgz

# Stable releases publish platform binaries to npm so fresh global installs
# do not depend on bun being present. Dev releases skip the build, so these
# entries are simply absent there.
!bin/ck-*

# Development files
src/
tests/
scripts/
docs/
plans/
.claude/
.github/
.githooks/

# Config files
*.config.js
*.config.ts
.releaserc.json
tsconfig.json
biome.json
.editorconfig
.gitignore

# Test artifacts
coverage/
*.test.ts
*.spec.ts

# Build artifacts that shouldn't be published
node_modules/

# Misc
*.log
*.md
!README.md
