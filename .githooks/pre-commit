#!/bin/bash
# Quality gate (pre-commit): typecheck + lint + build
# Catches the top 3 CI failure categories BEFORE code leaves the machine.
# Works in both normal repos and worktrees.

set -euo pipefail

cd "$(git rev-parse --show-toplevel)" || exit 1

# Allow CI/release tooling to skip hooks when needed
if [ "${CI:-}" = "true" ] || [ "${SKIP_HOOKS:-}" = "true" ]; then
  exit 0
fi

echo ""
echo "  Quality Gate (pre-commit)"
echo "  ========================="
echo ""

echo "  [1/3] Lint (auto-fix)..."
# Snapshot working tree state before lint so we only detect changes lint caused,
# not pre-existing unstaged work the developer intentionally left uncommitted.
DIFF_BEFORE=$(git diff --stat 2>/dev/null || true)
bun run lint:fix || {
  echo ""
  echo "  [X] Lint failed with unfixable errors. Fix before committing."
  exit 1
}
DIFF_AFTER=$(git diff --stat 2>/dev/null || true)

# If lint auto-fixed files (diff changed), abort so the user can review and re-stage.
if [ "$DIFF_BEFORE" != "$DIFF_AFTER" ]; then
  echo ""
  echo "  [!] Lint auto-fixed files. Review, stage, and commit again:"
  git diff --stat
  exit 1
fi

echo "  [2/3] Typecheck..."
bun run typecheck || {
  echo ""
  echo "  [X] Typecheck failed. Fix type errors before committing."
  exit 1
}

echo "  [3/3] Build..."
bun run build || {
  echo ""
  echo "  [X] Build failed. Fix errors before committing."
  exit 1
}

echo ""
echo "  [OK] Quality gate passed."
echo ""
