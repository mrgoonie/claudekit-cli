#!/bin/bash
# Quality gate (pre-push): typecheck + lint + build + test
# Full CI parity — nothing reaches upstream that wouldn't pass CI.
# Works in both normal repos and worktrees.

set -euo pipefail

cd "$(git rev-parse --show-toplevel)" || exit 1

# Allow CI/release tooling to skip hooks when needed
if [ "${CI:-}" = "true" ] || [ "${SKIP_HOOKS:-}" = "true" ]; then
  exit 0
fi

echo ""
echo "  Quality Gate (pre-push)"
echo "  ========================"
echo ""

echo "  [1/4] Typecheck..."
bun run typecheck || {
  echo ""
  echo "  [X] Typecheck failed."
  exit 1
}

echo "  [2/4] Lint..."
bun run lint || {
  echo ""
  echo "  [X] Lint failed."
  exit 1
}

echo "  [3/4] Build..."
bun run build || {
  echo ""
  echo "  [X] Build failed."
  exit 1
}

echo "  [4/4] Tests..."
# Suppress interactive prompts and enable CI-safe test behavior (matches ci.yml)
NON_INTERACTIVE=true CI_SAFE_MODE=true bun test || {
  echo ""
  echo "  [X] Tests failed."
  exit 1
}

echo ""
echo "  [OK] All checks passed. Pushing..."
echo ""
